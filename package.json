{
  "name": "@rendotdev/rig",
  "version": "0.0.24",
  "description": "Local typed command runtime for agents.",
  "homepage": "https://github.com/rendotdev/rig#readme",
  "bugs": {
    "url": "https://github.com/rendotdev/rig/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rendotdev/rig.git"
  },
  "bin": {
    "rig": "dist/rig.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun --install=fallback --watch run src/cli.ts",
    "build": "bun run scripts/build.ts",
    "bench": "bun run scripts/bench.ts",
    "release": "bun run scripts/release.ts",
    "release:patch": "bun run scripts/release.ts patch",
    "release:minor": "bun run scripts/release.ts minor",
    "release:major": "bun run scripts/release.ts major",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "test": "oxfmt . --check && oxlint . --deny-warnings && tsc --noEmit && vitest run --coverage",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@types/bun": "latest",
    "bun": "1.3.14",
    "commander": "latest",
    "pino": "^10.3.1",
    "typescript": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
