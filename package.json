{
  "name": "@rendotdev/rig",
  "version": "0.0.36",
  "description": "Local typed command runtime for agents.",
  "homepage": "https://github.com/rendotdev/rig#readme",
  "bugs": {
    "url": "https://github.com/rendotdev/rig/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rendotdev/rig.git"
  },
  "bin": {
    "rig": "dist/rig.mjs"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "bench": "bun run scripts/bench.ts",
    "release": "bun run scripts/release.ts",
    "release:patch": "bun run scripts/release.ts patch",
    "release:minor": "bun run scripts/release.ts minor",
    "release:major": "bun run scripts/release.ts major",
    "typecheck": "tsc --noEmit",
    "test:unit": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "coverage": "vp test run --coverage",
    "check": "vp check",
    "test": "vp test run --coverage",
    "prepack": "vp pack"
  },
  "dependencies": {
    "@types/bun": "latest",
    "bun": "1.3.14",
    "commander": "latest",
    "typescript": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.10",
    "pino": "^10.3.1",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.12.1"
}
