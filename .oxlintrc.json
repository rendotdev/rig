{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "builtin": true,
    "node": true,
    "vitest": true
  },
  "plugins": ["typescript", "unicorn", "promise", "node", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "typescript/no-extraneous-class": "off"
  },
  "ignorePatterns": ["dist/**", "coverage/**", "node_modules/**"]
}
